{
  "name": "jadeview",
  "displayName": "JadeView",
  "description": "View HTML as Pug and render XML/XSLT/XSD/Schematron (via unxml) for easier reading.",
  "version": "1.2.0",
  "publisher": "vivainio",
  "author": "Ville M. Vainio <vivainio@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivainio/jadeview"
  },
  "engines": {
    "vscode": "^1.74.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Formatters",
    "Visualization",
    "Programming Languages"
  ],
  "keywords": [
    "html",
    "pug",
    "xml",
    "unxml",
    "xslt",
    "xsd",
    "ubl",
    "converter",
    "formatter"
  ],
  "icon": "images/jadeview.png",
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "contributes": {
    "commands": [
      {
        "command": "extension.jadeView",
        "title": "Jade View"
      },
      {
        "command": "extension.unxml",
        "title": "Unxml: Render"
      },
      {
        "command": "extension.unxmlSelect",
        "title": "Unxml: Select Tag…"
      },
      {
        "command": "extension.unxmlSpecial",
        "title": "Unxml: Render (Special)"
      }
    ],
    "languages": [
      {
        "id": "unxml",
        "aliases": [
          "UnXML",
          "unxml"
        ],
        "extensions": [
          ".unxml"
        ],
        "configuration": "./unxml-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "unxml",
        "scopeName": "source.unxml",
        "path": "./syntaxes/unxml.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "JadeView",
      "properties": {
        "jadeview.unxmlExtraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra arguments appended to every unxml invocation, e.g. [\"--hide-ns\", \"cbc,cac\"]."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "compile:watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/tmp": "^0.2.6",
    "@types/vscode": "^1.74.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.46.0"
  },
  "dependencies": {
    "html2pug": "^4.0.0",
    "tmp": "^0.2.7"
  }
}
